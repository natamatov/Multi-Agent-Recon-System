# ===================================================
# M.A.R.S. — Multi-Agent Recon System
# Скопируйте этот файл в .env и заполните ключи
# ===================================================

# ===================================================
# НАСТРОЙКИ LLM
# ===================================================

# Провайдер LLM: anthropic, openai, ollama
LLM_PROVIDER=anthropic

# Модель (например, claude-3-5-sonnet-20241022, gpt-4o, llama3)
LLM_MODEL=claude-3-5-sonnet-20241022

# API Ключ (не требуется для ollama)
LLM_API_KEY=

# Базовый URL API (опционально, полезно для Ollama или локальных OpenAI-совместимых серверов)
# Для Ollama по умолчанию используется http://localhost:11434
LLM_API_BASE=

# [ОПЦИОНАЛЬНО] Цель аудита (IP, домен или URL)
# Если не задан — вводится вручную в UI (Streamlit) или CLI
TARGET=

# [ОПЦИОНАЛЬНО] NVD API Key — ускоряет верификацию CVE
# Лимит без ключа: 5 req/30s. С ключом: 50 req/30s
# Получить: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# [ОПЦИОНАЛЬНО] Shodan API Key — пассивный OSINT (порты, уязвимости без касания цели)
# Получить: https://account.shodan.io/
SHODAN_API_KEY=

# [ОПЦИОНАЛЬНО] VirusTotal API Key — проверка репутации домена/IP по 90+ антивирусным движкам
# Бесплатный план: 500 req/day, 4 req/min
# Получить: https://www.virustotal.com → профиль → API Key
VIRUSTOTAL_API_KEY=

# ===================================================
# РЕЖИМЫ АУДИТА (по умолчанию — только VA, без Red Team)
# ===================================================

# [ПО УМОЛЧАНИЮ: false] Включить Red Team агентов (PoC / Exploit режимы)
ENABLE_RED_TEAM=false

# [ПО УМОЛЧАНИЮ: false] Разрешить запуск эксплойтов (install + execute)
# Требует ENABLE_RED_TEAM=true. В UI также нужно двойное подтверждение.
ALLOW_EXPLOIT_EXECUTION=false

# [ОПЦИОНАЛЬНО] WPScan API Token — CVE по плагинам и темам WordPress
# Бесплатный план: 25 req/day
# Получить: https://wpscan.com/profile
WPSCAN_API_KEY=

# ===================================================
# СЕТЕВЫЕ НАСТРОЙКИ
# ===================================================

# [ОПЦИОНАЛЬНО] Сетевой интерфейс для nmap (-e <interface>)
# Примеры: eth0, wlan0, tun0 (VPN)
NETWORK_INTERFACE=

# [ОПЦИОНАЛЬНО] Исходящий IP для nmap (-S <ip>)
# Полезно если на интерфейсе несколько IP
SOURCE_IP=

# [ПО УМОЛЧАНИЮ: true] Умный выбор сканеров (пропуск nikto/wpscan если нет веба)
USE_SMART_SCANNERS=true

# ===================================================
# SCOPE / LEGAL GUARDRAILS
# ===================================================

# Требовать номер заявки в UI
SCOPE_TICKET_REQUIRED=false

# Разрешить сканирование RFC1918 / localhost (lab)
ALLOW_INTERNAL_TARGETS=false

# Требовать чекбокс подтверждения в UI
REQUIRE_SCOPE_CONFIRMATION=false

# Список разрешённых целей (через запятую), пусто = любая (с учётом internal)
# ALLOWED_TARGETS=*.example.com,10.0.0.0/8

# [ОПЦИОНАЛЬНО] HTTP-прокси для веб-сканеров (whatweb, nikto, ffuf, wpscan)
# Формат: http://host:port или socks5://host:port
# Пример (Burp Suite): http://127.0.0.1:8080
HTTP_PROXY=

# ===================================================
# НОВЫЕ ИНТЕГРАЦИИ v2
# ===================================================

# [ОПЦИОНАЛЬНО] GreyNoise API Key — классификация IP (шум vs. целевая атака)
# Бесплатный Community план: 1000 req/day
# Получить: https://www.greynoise.io/ → Sign Up → API Key
GREYNOISE_API_KEY=

# NVD_API_KEY уже поддерживался, теперь используется явно в Settings
# Получить: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# EPSS scoring работает без ключа (бесплатный API от FIRST.org)
# Документация: https://api.first.org/data/1.0/epss
